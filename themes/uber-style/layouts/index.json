{{- $.Scratch.Add "index" slice -}}
{{- range site.RegularPages -}}
    {{- $.Scratch.Add "index" (dict "title" .Title "permalink" .Permalink "description" .Params.description "date" .Date "tags" .Params.tags "categories" .Params.categories "readTime" .Params.readTime "weight" .Weight) -}}
{{- end -}}
{{- $.Scratch.Get "index" | jsonify -}}